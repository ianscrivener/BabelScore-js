{
    "project": "_example",
    "description": "BabelScore: Bislama ↔ English",
    "paradigm": 5,
    "source_language": "Bislama",
    "source_language_code": "bis",
    "target_language": "English",
    "target_language_code": "eng",
    "data_file_format": "csv",
