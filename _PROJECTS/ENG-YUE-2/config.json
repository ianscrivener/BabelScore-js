{
    "project": "_example",
    "description": "Example project: English ↔ French Cantonese quality benchmark",
    "paradigm": 5,
    "source_language": "English",
    "source_language_code": "en",
    "target_language": "Cantonese",
    "target_language_code": "yue",
    "data_file_format":"json",
    "data_file_combined":false,
    "data_files": [
        "data/zh_yue_test.json",
        "data/yue_zh_test.json"
    ],
    "max_sentences": 10,
    "translator_models": [
        {
            "id": "lmstudio-qwen3.5-35b-a3b",
            "provider": "lm_studio",
            "model": "qwen/qwen3.5-35b-a3b",
            "base_url": "http://localhost:1234/v1",
            "api_key": "",
            "auto_load": false,
            "auto_unload": false,
            "max_tokens": 1024,
            "temperature": 0.0
        }
    ],

    "judge_models": [
        {
            "id": "openrouter-gemini-3.1-pro",
            "provider": "openrouter",
            "model": "google/gemini-3.1-pro-preview",
            "base_url": "https://openrouter.ai/api/v1",
            "api_key": "${OPENROUTER_API_KEY}"
        }
    ],

    "output": {
        "format": "markdown",
        "results_dir": "results",
        "show_judge_reasoning": true,
        "flag_high_variance": true,
        "variance_threshold": 15
    }
}
